# ============================================================================
#  Bolao da Copa - Geração Eucarística
#  Copie este arquivo para .env e preencha com seus valores reais.
#  NUNCA commite o arquivo .env no GitHub.
# ============================================================================

# Banco de dados PostgreSQL (Supabase)
# DATABASE_URL = pooler (porta 6543) | DIRECT_URL = conexao direta (porta 5432)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[SENHA]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[SENHA]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"

# Supabase (opcional — usado se integrar auth/storage no futuro)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sua-chave-publica-aqui"

# NextAuth — gere um segredo forte: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="gere-um-segredo-longo-e-aleatorio-aqui"

# API de futebol (football-data.org)
FOOTBALL_PROVIDER="football-data"
FOOTBALL_DATA_TOKEN="seu-token-da-football-data-org"
FOOTBALL_COMPETITION="WC"
SYNC_INTERVAL_MS="180000"

# Admin inicial (criado pelo seed)
ADMIN_EMAIL="admin@grupojovem.com"
ADMIN_PASSWORD="defina-uma-senha-forte-aqui"
ADMIN_NAME="Coordenacao Grupo Jovem"

# Cron de sincronizacao (opcional — protege o endpoint /api/cron/sync)
CRON_SECRET="gere-outro-segredo-aleatorio-aqui"
